# App
APP_SECRET_KEY=change-me-to-a-64-byte-random-hex-string
APP_ENVIRONMENT=development
APP_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# Database
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password
DATABASE_URL=postgresql+asyncpg://raventech:replace-with-a-strong-postgres-password@postgres:5432/raventech
TEST_DATABASE_URL=postgresql+asyncpg://raventech:replace-with-a-strong-postgres-password@localhost:5432/raventech_test

# Redis
REDIS_PASSWORD=replace-with-a-strong-redis-password
REDIS_URL=redis://:replace-with-a-strong-redis-password@redis:6379/0

# ChromaDB local persistence path for the knowledge index.
CHROMA_DATA_PATH=/data/chroma

# AI analysis provider. Leave API key empty to return provider_unavailable.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Local Obsidian/Markdown knowledge source path.
OBSIDIAN_WIKI_PATH=

# OSINT API placeholders for later phases. Leave empty in Phase 0.
SHODAN_API_KEY=
VT_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=
URLSCAN_API_KEY=
SECURITYTRAILS_API_KEY=
CENSYS_API_ID=
CENSYS_SECRET=
HIBP_API_KEY=
GITHUB_TOKEN=

# Admin Bootstrap
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@raventech.mx
ADMIN_PASSWORD=replace-with-a-strong-admin-password
